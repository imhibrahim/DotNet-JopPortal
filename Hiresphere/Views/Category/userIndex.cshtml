@model IEnumerable<Hiresphere.Models.Category>

@{
    ViewData["Title"] = "Job Categories";
}

<div class="container py-5 mt-5" style="margin-bottom:150px">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-success">Browse Job Categories</h2>
        <p class="text-muted">
            Find jobs according to your skills and interests.
        </p>
    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="category-card">

                    <div class="icon-box">
                        <i class="fas fa-briefcase"></i>
                    </div>

                    <h4>@item.CategoryName</h4>

                    <p>
                        @item.Description
                    </p>

                    <a asp-action="CategoryJobs"
                       asp-controller="Jobseeker"
                       asp-route-id="@item.Id"
                       class="btn btn-success">
                        View Jobs
                    </a>

                </div>

            </div>
        }

    </div>

</div>

<style>

    body {
        background: #f8f9fa;
    }

    /* Card */

    .category-card {
        background: #fff;
        border-radius: 20px;
        padding: 30px 20px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0,0,0,.08);
        transition: .4s;
        height: 100%;
        border: 2px solid transparent;
    }

        .category-card:hover {
            transform: translateY(-10px);
            border-color: #00c853;
            box-shadow: 0 20px 40px rgba(0,200,83,.25);
        }

    /* Icon */

    .icon-box {
        width: 80px;
        height: 80px;
        background: #e8fff0;
        border-radius: 50%;
        margin: auto;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: .4s;
    }

        .icon-box i {
            font-size: 35px;
            color: #00c853;
            transition: .4s;
        }

    .category-card:hover .icon-box {
        background: #00c853;
    }

        .category-card:hover .icon-box i {
            color: white;
        }

    .category-card h4 {
        margin-top: 20px;
        font-weight: 700;
    }

    .category-card p {
        color: #777;
        min-height: 70px;
    }

    .btn-success {
        border-radius: 30px;
        padding: 8px 25px;
    }

</style>