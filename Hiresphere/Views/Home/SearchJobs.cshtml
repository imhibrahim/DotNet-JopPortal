@model IEnumerable<Hiresphere.Models.Job>

@{
    ViewData["Title"] = "Search Jobs";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">


<style>

    body {
        background: #f5f8f6;
    }


    .search-title {
        color: #087f5b;
        font-weight: 800;
    }


    .job-card {
        background: white;
        border: none;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        transition: .4s;
    }


        .job-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(16,163,127,.25);
        }



    .job-header {
        background: linear-gradient(135deg,#10A37F,#00c853);
        color: white;
        padding: 25px;
    }


        .job-header h4 {
            font-weight: 700;
        }


    .detail {
        color: #555;
        margin-bottom: 12px;
    }


        .detail i {
            color: #10A37F;
            width: 25px;
        }



    .salary {
        color: #198754;
        font-weight: bold;
    }



    .btn-details {
        border-radius: 30px;
        padding: 10px 30px;
    }



    .no-job {
        background: white;
        border-radius: 25px;
        padding: 60px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,.1);
    }


        .no-job i {
            font-size: 80px;
            color: #10A37F;
        }

</style>



<div class="container py-5 mt-5 mb-5">


    <h2 class="text-center search-title mb-5">

        <i class="fa-solid fa-magnifying-glass"></i>

        Search Jobs Result

    </h2>



    @if (Model != null && Model.Any())
    {

        <div class="row g-4">


            @foreach (var item in Model)
            {

                <div class="col-lg-4 col-md-6">


                    <div class="job-card h-100">


                        <div class="job-header">

                            <h4>
                                @item.Title
                            </h4>


                            <p class="mb-0">

                                <i class="fa-solid fa-building"></i>

                                @item.Company?.CompanyName

                            </p>


                        </div>



                        <div class="p-4">


                            <div class="detail">

                                <i class="fa-solid fa-location-dot"></i>

                                @item.Location

                            </div>



                            <div class="detail">

                                <i class="fa-solid fa-layer-group"></i>

                                @item.Category?.CategoryName

                            </div>



                            <div class="detail salary">

                                <i class="fa-solid fa-money-bill"></i>

                                Rs. @item.Salary

                            </div>



                            <div class="detail">

                                <i class="fa-solid fa-briefcase"></i>

                                @item.JobType

                            </div>



                            <div class="detail">

                                <i class="fa-solid fa-calendar-days"></i>

                                Deadline:
                                @item.Deadline.ToString("dd MMM yyyy")

                            </div>



                            <a asp-action="jobdetail"
                               asp-controller="joblist"
                               asp-route-id="@item.Id"
                               class="btn btn-success btn-details w-100 mt-3">


                                <i class="fa-solid fa-eye"></i>

                                View Details


                            </a>


                        </div>


                    </div>


                </div>

            }


        </div>


    }
    else
    {

        <div class="no-job">


            <i class="fa-solid fa-folder-open"></i>


            <h2 class="mt-4">

                No Jobs Found

            </h2>


            <p class="text-muted">

                Sorry! No job is available according to your search.

            </p>


            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-success rounded-pill px-4">

                Back To Home

            </a>


        </div>

    }


</div>