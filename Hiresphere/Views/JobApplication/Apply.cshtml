@model Hiresphere.Models.Jobwithimage

@{
    ViewData["Title"] = "Apply Job";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Apply Job | HireSphere</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <style>

            body {
                background: linear-gradient(135deg,#10A37F,#0E8F6F);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 40px;
                font-family: 'Segoe UI', sans-serif;
            }

            .apply-card {
                width: 850px;
                background: #fff;
                border-radius: 20px;
                padding: 35px;
                box-shadow: 0 20px 40px rgba(0,0,0,.2);
            }

            .logo {
                width: 90px;
                height: 90px;
                margin: auto;
                border-radius: 50%;
                background: #10A37F;
                display: flex;
                justify-content: center;
                align-items: center;
                color: white;
                font-size: 35px;
                margin-bottom: 20px;
            }

            .form-control {
                border-radius: 10px;
            }

            textarea {
                resize: none;
                height: 120px;
            }

            .btn-success {
                border-radius: 30px;
                padding: 10px 35px;
            }

    </style>

</head>
<body>

    <div class="apply-card">

        <div class="logo">
            <i class="fa-solid fa-briefcase"></i>
        </div>

        <h2 class="text-center mb-2">Apply For Job</h2>

        <p class="text-center text-muted mb-4">
            Fill the application form and upload your cover letter.
        </p>

        <form asp-action="Apply" method="post" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="JobId" />
            <input type="hidden" asp-for="Resume" />

            <!-- Job Title -->

            <div class="mb-3">

                <label class="form-label fw-bold">
                    Job Title
                </label>

                <input asp-for="JobTitle"
                       class="form-control"
                       readonly />

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input asp-for="FullName" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input asp-for="Email" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Phone</label>
                    <input asp-for="Phone" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Address</label>
                    <input asp-for="Address" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Education</label>
                    <input asp-for="Education" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Experience</label>
                    <input asp-for="Experience" class="form-control" readonly />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Skills</label>
                    <textarea asp-for="Skills" class="form-control" readonly></textarea>
                </div>

            </div>

            @if (!string.IsNullOrEmpty(Model.Resume))
            {
                <div class="mb-3">

                    <label class="form-label fw-bold">
                        Resume
                    </label>

                    <br />

                    <a href="@Model.Resume"
                       target="_blank"
                       class="btn btn-outline-success">

                        <i class="fa-solid fa-file"></i>
                        View Resume

                    </a>

                </div>
            }

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Upload Cover Letter
                </label>

                <input asp-for="CV"
                       type="file"
                       class="form-control" />

                <span asp-validation-for="CV" class="text-danger"></span>

            </div>

            <div class="text-center">

                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-paper-plane"></i>
                    Apply Now
                </button>

            </div>

        </form>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>