@model IEnumerable<Hiresphere.Models.JobApplication>

@{
    ViewData["Title"] = "My Applications";
}



    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">

    <style>

            body {
                background: #f4f7fb;
            }

            .page-title {
                font-weight: 700;
                color: #198754;
            }

            .job-card {
                border: none;
                border-radius: 20px;
                overflow: hidden;
                transition: .4s;
                box-shadow: 0 10px 25px rgba(0,0,0,.08);
                background: #fff;
            }

                .job-card:hover {
                    transform: translateY(-10px) scale(1.02);
                    box-shadow: 0 20px 40px rgba(25,135,84,.25);
                }

            .card-header-custom {
                background: linear-gradient(135deg,#10A37F,#0E8F6F);
                color: white;
                padding: 20px;
            }

            .company {
                font-size: 15px;
                opacity: .9;
            }

            .detail {
                margin-bottom: 10px;
                color: #555;
            }

                .detail i {
                    width: 25px;
                    color: #198754;
                }

            .status {
                font-size: 14px;
                padding: 8px 18px;
                border-radius: 30px;
            }

            .btn-view {
                border-radius: 30px;
                transition: .3s;
            }

                .btn-view:hover {
                    transform: scale(1.08);
                }

            .empty-box {
                background: white;
                padding: 60px;
                border-radius: 20px;
                text-align: center;
                box-shadow: 0 10px 25px rgba(0,0,0,.08);
            }

            .icon-big {
                font-size: 70px;
                color: #198754;
            }

    </style>


    <div class="container py-5" style="margin-top:150px; margin-bottom:150px">

        <h2 class="text-center page-title mb-5">
            <i class="fa-solid fa-briefcase"></i>
            My Applied Jobs
        </h2>

        @if (!Model.Any())
        {
            <div class="empty-box">

                <i class="fa-solid fa-folder-open icon-big mb-3"></i>

                <h3>No Applications Found</h3>

                <p class="text-muted">
                    You haven't applied for any jobs yet.
                </p>

            </div>
        }
        else
        {

            <div class="row">

                @foreach (var item in Model)
                {

                    <div class="col-lg-4 col-md-6 mb-4">

                        <div class="card job-card h-100">

                            <div class="card-header-custom">

                                <h4>@item.Job.Title</h4>

                                <div class="company">
                                    <i class="fa-solid fa-building"></i>
                                    @item.Job.Company
                                </div>

                            </div>

                            <div class="card-body">

                                <div class="detail">
                                    <i class="fa-solid fa-location-dot"></i>
                                    @item.Job.Location
                                </div>

                                <div class="detail">
                                    <i class="fa-solid fa-calendar-days"></i>
                                    @item.AppliedDate.ToString("dd MMM yyyy")
                                </div>

                                <div class="detail">

                                    <i class="fa-solid fa-circle-info"></i>

                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark status">
                                            Pending
                                        </span>
                                    }
                                    else if (item.Status == "Accepted")
                                    {
                                        <span class="badge bg-success status">
                                            Accepted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger status">
                                            Rejected
                                        </span>
                                    }

                                </div>

                            </div>

                            <div class="card-footer bg-white border-0 pb-4 text-center">

                                <a href="@item.CoverLetter"
                                   target="_blank"
                                   class="btn btn-success btn-view">

                                    <i class="fa-solid fa-file"></i>
                                    View Resume

                                </a>

                            </div>

                        </div>

                    </div>

                }

            </div>

        }

    </div>

