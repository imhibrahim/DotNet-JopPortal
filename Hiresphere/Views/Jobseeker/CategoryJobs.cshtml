@model IEnumerable<Hiresphere.Models.Job>

@{
    ViewData["Title"] = "Category Jobs";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fa;
    }

    .title {
        font-size: 35px;
        font-weight: bold;
        color: #198754;
    }

    .job-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: .4s;
        box-shadow: 0 8px 20px rgba(0,0,0,.1);
    }

        .job-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,.2);
        }

    .header {
        background: linear-gradient(135deg,#10A37F,#0E8F6F);
        color: white;
        padding: 20px;
    }

    .info {
        margin-bottom: 10px;
    }

    .empty {
        margin-top: 100px;
        text-align: center;
    }

        .empty i {
            font-size: 100px;
            color: #198754;
        }

</style>

<div class="container py-5" style="margin-top:150px;margin-bottom:150px;">

    <h2 class="text-center title mb-5">

        @ViewBag.Category Jobs

    </h2>

    @if (Model.Any())
    {

        <div class="row">

            @foreach (var item in Model)
            {

                <div class="col-lg-4 mb-4">

                    <div class="card job-card">

                        <div class="header">

                            <h4>@item.Title</h4>

                        </div>

                        <div class="card-body">

                            <p class="info">
                                <i class="fa-solid fa-building text-success"></i>
                                @item.Company.CompanyName
                            </p>

                            <p class="info">
                                <i class="fa-solid fa-location-dot text-danger"></i>
                                @item.Location
                            </p>

                            <p class="info">
                                <i class="fa-solid fa-money-bill text-success"></i>
                                Rs. @item.Salary
                            </p>

                            <p class="info">
                                <i class="fa-solid fa-briefcase text-primary"></i>
                                @item.JobType
                            </p>

                            <p class="info">
                                <i class="fa-solid fa-calendar text-warning"></i>
                                @item.Deadline.ToString("dd MMM yyyy")
                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a asp-action="jobdetail"
                            asp-controller="joblist"
                               asp-route-id="@item.Id"
                               class="btn btn-success w-100">

                                View Details

                            </a>

                        </div>

                    </div>

                </div>

            }

        </div>

    }
    else
    {

        <div class="empty">

            <i class="fa-solid fa-folder-open"></i>

            <h2 class="mt-4">

                No Jobs Available

            </h2>

            <p class="text-muted">

                Sorry! There are currently no jobs available in
                <b>@ViewBag.Category</b> category.

            </p>

            <a asp-action="JobList" asp-controller="joblist"
               class="btn btn-success px-4">

                Browse All Jobs

            </a>

        </div>

    }

</div>