@model Hiresphere.Models.Employee

@{
    ViewData["Title"] = "Company Profile";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fa;
    }

    .profile-card {
        max-width: 900px;
        margin: auto;
        margin-top: 60px;
        margin-bottom: 60px;
        background: white;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,.1);
    }

    .header {
        background: linear-gradient(135deg,#10A37F,#0E8F6F);
        color: white;
        text-align: center;
        padding: 50px;
    }

    .logo {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        border: 6px solid white;
        background: white;
    }

    .body {
        padding: 40px;
    }

    .info {
        font-size: 18px;
        margin-bottom: 20px;
    }

        .info i {
            color: #10A37F;
            width: 35px;
        }

    .stat {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
    }

        .stat h3 {
            color: #10A37F;
            font-weight: bold;
        }

    .btn-back {
        border-radius: 30px;
        padding: 10px 30px;
    }

</style>

<div class="container">

    <div class="profile-card">

        <div class="header">

            @if (!string.IsNullOrEmpty(Model.Logo))
            {
                <img src="@Model.Logo" class="logo" />
            }
            else
            {
                <img src="https://via.placeholder.com/150" class="logo" />
            }

            <h2 class="mt-3">@Model.CompanyName</h2>

            <h5>@Model.OwnerName</h5>

        </div>

        <div class="body">

            <div class="row">

                <div class="col-md-8">

                    <div class="info">
                        <i class="fa-solid fa-envelope"></i>
                        @Model.Email
                    </div>

                    <div class="info">
                        <i class="fa-solid fa-phone"></i>
                        @Model.Phone
                    </div>

                    <div class="info">
                        <i class="fa-solid fa-location-dot"></i>
                        @Model.Location
                    </div>

                    <div class="info">
                        <i class="fa-solid fa-globe"></i>
                        <a href="@Model.Website" target="_blank">
                            @Model.Website
                        </a>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-4">

                            <h4>About Company</h4>

                            <p class="text-muted">
                                @Model.Description
                            </p>

                        </div>
                    }

                </div>

                <div class="col-md-4">

                    <div class="stat">

                        <h3>@ViewBag.TotalJobs</h3>

                        <p>Total Jobs</p>

                    </div>

                </div>

            </div>

            <div class="text-center mt-5">

                <a asp-action="Index"
                   class="btn btn-success btn-back">

                    <i class="fa-solid fa-arrow-left"></i>

                    Back

                </a>

            </div>

        </div>

    </div>

</div>